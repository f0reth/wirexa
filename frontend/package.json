{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "tsc -b && bunx --bun vite build",
    "preview": "vite preview",
    "tsc": "tsc -b",
    "lint": "bunx biome check",
    "format": "bunx biome check --write",
    "ci": "bunx biome ci",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:e2e": "bunx --bun vite --config vite.e2e.config.ts",
    "test:e2e:setup": "bunx playwright install chromium",
    "test:e2e": "bunx playwright test",
    "test:e2e:fullstack": "bunx playwright test --config playwright.integration.config.ts",
    "licenses": "bun scripts/generate-licenses.mjs"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/lint": "^6.9.7",
    "@corvu/resizable": "^0.2.5",
    "@tanstack/solid-virtual": "^3.13.30",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "lucide-solid": "^1.21.0",
    "rapidoc": "^9.3.8",
    "solid-js": "^1.9.13",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.9.4",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.9"
  }
}
